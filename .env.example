# ─── SvelteKit (.env.example) ───────────────────────────────────────────────────
# These are read by Vite / SvelteKit. Do NOT put Convex secrets here.

CONVEX_DEPLOYMENT=dev:your-team,project-name
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

PUBLIC_LIVEBLOCKS_KEY=pk_live_...
LIVEBLOCKS_SECRET_KEY=sk_live_...

# ─── Convex environment variables ─────────────────────────────────────────────
# SvelteKit hooks call createAuth() server-side, so these must be here too.
# Keep the values in sync with: npx convex env set <KEY> "value"
# Set them via CLI:
#
#   npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"
#   npx convex env set SITE_URL "http://localhost:5173"
#   npx convex env set GITHUB_CLIENT_ID "your-client-id"
#   npx convex env set GITHUB_CLIENT_SECRET "your-client-secret"

BETTER_AUTH_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

SITE_URL=http://localhost:5173