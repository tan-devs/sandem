{
	"name": "sandem",
	"author": "tan-devs",
	"version": "0.0.1",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tan-devs/sandem.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev:client": "vite dev --host",
		"dev:server": "npx convex dev",
		"dev": "concurrently --kill-others --prefix-colors red,yellow --names \"svelte,convex\" \"pnpm dev:client\" \"pnpm dev:server\"",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:e2e:install-browsers": "PLAYWRIGHT_BROWSERS_PATH=node_modules/.cache/ms-playwright pnpm exec playwright install",
		"test:e2e": "PLAYWRIGHT_BROWSERS_PATH=node_modules/.cache/ms-playwright playwright test",
		"test:e2e:ui": "playwright test --ui",
		"setup:test-user": "npx tsx scripts/setup-test-user.ts",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish"
	},
	"files": [
		"dist/svelte",
		"dist/sveltekit",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"import": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./sveltekit": {
			"types": "./dist/sveltekit/index.d.ts",
			"import": "./dist/sveltekit/index.js",
			"default": "./dist/sveltekit/index.js"
		}
	},
	"peerDependencies": {
		"@convex-dev/better-auth": ">=0.10.10",
		"better-auth": "^1.4.9",
		"convex": "^1.31.0",
		"convex-svelte": ">=0.0.12",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@convex-dev/eslint-plugin": "^1.1.1",
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.2.2",
		"@vitest/browser": "^4.0.18",
		"better-auth": "1.4.9",
		"concurrently": "^9.2.1",
		"convex": "^1.31.7",
		"dotenv": "^17.2.4",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"jsdom": "^28.0.0",
		"playwright": "link:@vitest/browser/providers/playwright",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"publint": "^0.3.17",
		"svelte": "^5.50.0",
		"svelte-check": "^4.3.6",
		"svelte-eslint-parser": "^1.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2",
		"y-protocols": "^1.0.0"
	},
	"keywords": [
		"svelte"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"peerDependencyRules": {
			"allowAny": [
				"zod",
				"eslint"
			],
			"ignoreMissing": [
				"zod",
				"eslint"
			]
		},
		"overrides": {
			"zod": "^4.1.13",
			"eslint": "^9.39.2",
			"yjs": "^13.0.0",
			"y-protocols": "^1.0.0",
			"better-auth": "1.4.9",
			"better-all": "1.1.7"
		}
	},
	"dependencies": {
		"@battlefieldduck/xterm-svelte": "^2.2.1",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/state": "^6.5.4",
		"@liveblocks/client": "^3.14.0",
		"@liveblocks/node": "^3.14.0",
		"@liveblocks/yjs": "^3.14.0",
		"@mmailaender/convex-better-auth-svelte": "^0.5.1",
		"@monaco-editor/loader": "^1.7.0",
		"@sveltejs/kit": "^2.53.0",
		"@webcontainer/api": "^1.6.1",
		"@xterm/xterm": "^6.0.0",
		"bits-ui": "^2.16.0",
		"codemirror": "^6.0.2",
		"is-network-error": "^1.3.0",
		"monaco-editor": "^0.55.1",
		"paneforge": "^1.0.2",
		"phosphor-svelte": "^3.1.0",
		"y-codemirror.next": "^0.3.5",
		"y-monaco": "^0.1.6",
		"yjs": "^13.6.29",
		"zod": "^3.25.76"
	}
}
